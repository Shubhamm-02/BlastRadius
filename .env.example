# Neo4j AuraDB connection (from the "Connect" tab of your AuraDB instance)
# Copy this file to .env.local and fill in your values.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-generated-password

# Optional: enables the AI blast-radius explanation. Without it, a deterministic
# summary is shown instead, so the app still works.
ANTHROPIC_API_KEY=
